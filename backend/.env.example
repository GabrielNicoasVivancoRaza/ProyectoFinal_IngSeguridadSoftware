# Copia este archivo a .env y ajusta los valores. NUNCA subas el .env real.

# Aplicacion
APP_NAME="Plataforma Segura de Firma Digital"
ENVIRONMENT=development
DEBUG=true

# Base de datos PostgreSQL (pgAdmin4)
# Formato: postgresql+psycopg2://usuario:password@host:puerto/basededatos
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/firma_digital

# Seguridad / JWT (genera una clave fuerte para produccion)
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-y-larga
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256
