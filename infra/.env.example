# Copia a .env y ajusta. NUNCA subas el .env real al repositorio.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esta-password
POSTGRES_DB=firma_digital

# Backend
# Genera una clave fuerte con: openssl rand -hex 32
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-y-larga
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Origenes permitidos por CORS (separados por coma). Usa "*" solo en desarrollo.
CORS_ALLOW_ORIGINS=*
